# Copy this file to .env and fill in your project details

# Supabase — get from: https://supabase.com → Your Project → Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudflare Turnstile — get from: https://dash.cloudflare.com → Turnstile
# The SITE KEY is public (safe to put here). The SECRET KEY goes in Supabase only.
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key-here

# Web Push Notifications — VAPID public key
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here
